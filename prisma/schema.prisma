generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// User profile extending Clerk user data
model User {
  id       String   @id @default(cuid())
  clerkId  String   @unique
  email    String   @unique
  role     UserRole @default(STUDENT)

  // Profile information
  firstName String?
  lastName  String?
  birthDate DateTime?

  // Student-specific fields
  grade    Int?
  school   School?  @relation(fields: [schoolId], references: [id])
  schoolId String?

  // Parent-child relationship
  parentId String?
  parent   User?   @relation("ParentChild", fields: [parentId], references: [id])
  children User[]  @relation("ParentChild")

  // COPPA Consent tracking
  isUnder13        Boolean       @default(false)
  consentStatus    ConsentStatus @default(NOT_REQUIRED)
  consentGrantedAt DateTime?
  consentGrantedBy String? // Clerk ID of parent who granted consent

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  teamMemberships TeamMember[]
  progress        Progress?
  badges          UserBadge[]

  @@map("users")
}

enum UserRole {
  STUDENT
  TEACHER
  PARENT
  EXECUTIVE
  VOLUNTEER
}

enum ConsentStatus {
  NOT_REQUIRED // 13 or older
  PENDING // Waiting for parent approval
  GRANTED // Parent approved
  DENIED // Parent denied
}

model School {
  id      String  @id @default(cuid())
  name    String
  city    String?
  state   String?
  country String  @default("US")

  users User[]
  teams Team[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("schools")
}

model Team {
  id         String  @id @default(cuid())
  name       String
  school     School? @relation(fields: [schoolId], references: [id])
  schoolId   String?
  inviteCode String  @unique @default(cuid())

  members TeamMember[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("teams")
}

model TeamMember {
  id     String   @id @default(cuid())
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String
  team   Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId String
  role   TeamRole @default(MEMBER)

  joinedAt DateTime @default(now())

  @@unique([userId, teamId])
  @@map("team_members")
}

enum TeamRole {
  OWNER // Teacher who created the team
  ADVISOR // Additional teachers/advisors
  MEMBER // Student
}

// Progress tracking (skeleton for Phase 1)
model Progress {
  id     String @id @default(cuid())
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @unique

  // Gamification
  points      Int @default(0)
  level       Int @default(1)
  streakDays  Int @default(0)
  lastActiveAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("progress")
}

// Badge system (skeleton for Phase 1)
model Badge {
  id          String @id @default(cuid())
  slug        String @unique
  name        String
  description String
  iconUrl     String?
  category    String // modelun, mocktrial, mathletes, general

  users UserBadge[]

  @@map("badges")
}

model UserBadge {
  id      String @id @default(cuid())
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId  String
  badge   Badge  @relation(fields: [badgeId], references: [id])
  badgeId String

  earnedAt DateTime @default(now())

  @@unique([userId, badgeId])
  @@map("user_badges")
}

// Consent request tracking for COPPA
model ConsentRequest {
  id          String   @id @default(cuid())
  childId     String // Clerk ID of child
  parentEmail String
  token       String   @unique @default(cuid())
  status      ConsentRequestStatus @default(PENDING)

  createdAt   DateTime @default(now())
  expiresAt   DateTime
  respondedAt DateTime?

  @@map("consent_requests")
}

enum ConsentRequestStatus {
  PENDING
  APPROVED
  DENIED
  EXPIRED
}
